<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:ns1="http://schemas.android.com/tools">
    <color name="snake_accent">#1F8C3A</color>
    <color name="snake_bg">#F4FFF4</color>
    <color name="snake_body">#67C877</color>
    <color name="snake_food">#FF6B4A</color>
    <color name="snake_grid">#D1EDD3</color>
    <color name="snake_head">#3FA451</color>
    <color name="snake_panel">#E7F9E8</color>
    <color name="snake_text">#153020</color>
    <color name="splash_bg">#DAF5DD</color>
    <string name="app_name">Snake</string>
    <string name="best_score_label">Best: %1$d</string>
    <string name="game_over">Game Over</string>
    <string name="pause">Pause</string>
    <string name="restart">Restart</string>
    <string name="resume">Resume</string>
    <string name="score_label">Score: %1$d</string>
    <string name="speed_label">Speed: %1$d</string>
    <string name="start">Start</string>
    <string name="tap_to_start">Swipe or use arrows to play</string>
    <string name="try_again">Try Again</string>
    <style name="Theme.Snake" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/snake_panel</item>
        <item name="android:windowLightStatusBar" ns1:targetApi="m">true</item>
    </style>
    <style name="Theme.Snake.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_snake_cartoon</item>
        <item name="windowSplashScreenAnimationDuration">600</item>
        <item name="postSplashScreenTheme">@style/Theme.Snake</item>
    </style>
</resources>